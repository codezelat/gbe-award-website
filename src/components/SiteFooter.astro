---
import SocialLinks from "./SocialLinks";
import ImagePreview from "./ImagePreview.astro";
import LondonBusinessConsultancyLogo from "./LondonBusinessConsultancyLogo.astro";
import { assetPaths, footerItems } from "../data/home";
---

<footer class="bg-gbe-footer pb-24 pt-16 text-center max-[560px]:pb-16 max-[560px]:pt-[52px]">
  <div class="container-gbe">
    <h2 class="gold-text mb-[34px] mt-0 text-[clamp(26px,2.5vw,34px)] font-bold leading-[1.15] max-[560px]:text-[clamp(22px,6vw,26px)]">Global Business Excellence Awards</h2>
    <nav class="flex flex-wrap justify-center gap-[38px] max-[560px]:flex-col max-[560px]:gap-[22px]" aria-label="Footer navigation">
      {footerItems.map((item, index) => <a class:list={["text-[15px] font-bold tracking-[0.04em] text-gbe-text transition-colors duration-200 hover:text-gbe-gold", index === 0 && "text-gbe-gold"]} href={item.href}>{item.label}</a>)}
    </nav>
    <p class="mx-auto mb-7 mt-10 max-w-[760px] text-[clamp(14px,1.2vw,16px)] font-normal leading-[1.7] text-gbe-muted max-[560px]:max-w-[480px] max-[560px]:text-sm">
      Organised by London Business Consultancy in London, UK, GBE Awards 2026 is the premier platform for
      recognising organisations and individuals who shape the future. From innovation and leadership to social
      impact and enterprise, we spotlight excellence across London, Colombo, and the global business community.
    </p>
    <div class="footer-affiliation-row" aria-label="London Business Consultancy with United Kingdom and Sri Lanka presence">
      <img class="footer-country-flag" src={assetPaths.unitedKingdomFlag} alt="United Kingdom" width="64" height="64" loading="lazy" decoding="async" />
      <LondonBusinessConsultancyLogo />
      <img class="footer-country-flag" src={assetPaths.sriLankaFlag} alt="Sri Lanka" width="64" height="64" loading="lazy" decoding="async" />
    </div>
    <SocialLinks compact />
    <a class="mt-7 block text-sm font-normal text-gbe-muted" href="/privacy-policy">Privacy Policy</a>
    <small class="mt-[52px] block text-sm font-normal text-gbe-muted">© 2026 Global Business Excellence Awards</small>
    <small class="mt-3.5 block text-sm font-normal text-gbe-muted">Website Developed by <a class="font-bold text-gbe-gold-soft transition-colors duration-200 hover:text-gbe-gold" href="https://codezela.com" target="_blank" rel="noopener noreferrer">Codezela Technologies</a></small>
  </div>
</footer>
<ImagePreview />
