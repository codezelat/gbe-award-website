---
import SocialLinks from "./SocialLinks";
import { assetPaths } from "../data/home";
---

<section class="hero-section" aria-labelledby="hero-title">
  <div class="hero-video" aria-hidden="true">
    <iframe
      src="https://www.youtube-nocookie.com/embed/q5o6H2CDm9s?autoplay=1&mute=1&controls=0&loop=1&playlist=q5o6H2CDm9s&rel=0&playsinline=1&cc_load_policy=0&enablejsapi=1"
      title="GBE AWARD BG"
      loading="eager"
      allow="autoplay; encrypted-media; picture-in-picture"
      tabindex="-1"
    ></iframe>
  </div>
  <div class="hero-video-overlay" aria-hidden="true"></div>
  <div class="hero-inner">
    <img class="hero-trophy hero-trophy--left" src={assetPaths.trophy} alt="" width="177" height="550" decoding="async" />
    <div class="hero-copy reveal">
      <h1 id="hero-title">Global Business<br />Excellence Awards</h1>
      <p>
        Celebrate achievements, honor innovation, and inspire greatness. Join us in awarding the best in
        class across multiple categories where your excellence meets recognition.
      </p>
      <a class="gold-button" href="/apply">APPLY NOW <span aria-hidden="true">◎</span></a>
    </div>
    <img class="hero-trophy hero-trophy--right" src={assetPaths.trophy} alt="" width="177" height="550" decoding="async" />
  </div>

  <SocialLinks />
</section>
