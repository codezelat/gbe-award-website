---
import HeroLiveBackground from "./HeroLiveBackground";
import SocialLinks from "./SocialLinks";
import { assetPaths } from "../data/home";
---

<section class="relative -mt-[100px] min-h-[832px] overflow-hidden bg-gbe-bg pt-[306px] max-[1024px]:-mt-[120px] max-[1024px]:min-h-[700px] max-[1024px]:pt-[235px] max-[560px]:-mt-[100px] max-[560px]:min-h-[625px] max-[560px]:pt-[190px]" aria-labelledby="hero-title">
  <div class="pointer-events-none absolute inset-0 z-0 bg-[var(--c-page-glow)]" aria-hidden="true"></div>
  <HeroLiveBackground client:load />
  <div class="pointer-events-none absolute inset-0 z-[1] bg-[var(--c-hero-overlay)]" aria-hidden="true"></div>
  <div class="container-gbe relative z-[2] grid min-h-[530px] grid-cols-[250px_minmax(0,650px)_250px] items-center justify-center gap-[55px] max-[1024px]:flex max-[1024px]:min-h-0 max-[1024px]:flex-col max-[1024px]:gap-[22px]">
    <img class="h-[390px] w-[240px] justify-self-start object-contain drop-shadow-[0_20px_24px_rgba(17,80,255,0.22)] animate-[mediaFade_480ms_ease_both,trophyFloat_5.8s_ease-in-out_infinite] max-[1024px]:h-[364px] max-[1024px]:w-[224px] max-[560px]:h-[286px] max-[560px]:w-[176px]" src={assetPaths.trophy} alt="" width="800" height="1300" loading="eager" decoding="async" fetchpriority="high" />
    <div class="flex animate-[revealUp_760ms_both_ease] flex-col items-center text-center max-[560px]:-mt-1">
      <h1 id="hero-title" class="gold-text m-0 max-w-[770px] text-[clamp(48px,5vw,72px)] font-black leading-none max-[1024px]:text-[clamp(26px,6vw,36px)] max-[1024px]:leading-[1.05] max-[560px]:text-[23px]">Global Business<br />Excellence Awards</h1>
      <p class="mb-7 mt-8 max-w-[770px] text-[clamp(16px,1.5vw,19px)] font-normal leading-[1.6] text-gbe-muted max-[1024px]:mx-auto max-[1024px]:mb-0 max-[1024px]:mt-4 max-[1024px]:w-[var(--container)] max-[1024px]:text-[15px] max-[560px]:mt-3 max-[560px]:text-[14px] max-[560px]:leading-[1.5]">
        Recognising outstanding businesses and visionaries across the UK, Sri Lanka, and the world. We celebrate
        the achievements that define a new era of global excellence.
      </p>
      <a class="btn-gold btn-gold-hover max-[1024px]:hidden" href="/contact">Apply Now</a>
    </div>
    <img class="h-[390px] w-[240px] justify-self-end object-contain drop-shadow-[0_20px_24px_rgba(17,80,255,0.22)] animate-[mediaFade_480ms_ease_both,trophyFloat_5.8s_ease-in-out_infinite] [animation-delay:-2.2s] max-[1024px]:hidden" src={assetPaths.trophy} alt="" width="800" height="1300" loading="eager" decoding="async" />
  </div>

  <SocialLinks />
</section>
