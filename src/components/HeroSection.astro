---
import SocialLinks from "./SocialLinks";
import { assetPaths } from "../data/home";
---

<section class="relative -mt-[100px] min-h-[832px] overflow-hidden bg-black pt-[306px] max-[1024px]:-mt-[120px] max-[1024px]:min-h-[700px] max-[1024px]:pt-[235px] max-[560px]:-mt-[100px] max-[560px]:min-h-[625px] max-[560px]:pt-[190px]" aria-labelledby="hero-title">
  <div class="pointer-events-none absolute inset-0 z-0 opacity-[0.68] max-[1024px]:hidden" aria-hidden="true">
    <iframe
      class="absolute left-1/2 top-1/2 h-[max(100vh,56.25vw)] w-[max(100vw,220vh)] -translate-x-1/2 -translate-y-1/2 border-0"
      src="https://www.youtube-nocookie.com/embed/q5o6H2CDm9s?autoplay=1&mute=1&controls=0&loop=1&playlist=q5o6H2CDm9s&rel=0&playsinline=1&cc_load_policy=0&enablejsapi=1"
      title="GBE AWARD BG"
      loading="eager"
      allow="autoplay; encrypted-media; picture-in-picture"
      tabindex="-1"
    ></iframe>
  </div>
  <div class="pointer-events-none absolute inset-0 z-[1] bg-[radial-gradient(circle_at_50%_47%,rgba(0,0,0,0.22),rgba(0,0,0,0.68)_50%,#000_82%),linear-gradient(#000_0_7%,transparent_20%_74%,#000_100%)]" aria-hidden="true"></div>
  <div class="container-gbe relative z-[2] grid min-h-[530px] grid-cols-[225px_minmax(0,790px)_225px] items-center justify-center gap-20 max-[1024px]:flex max-[1024px]:min-h-0 max-[1024px]:flex-col max-[1024px]:gap-[22px]">
    <img class="h-[450px] w-[145px] justify-self-start object-contain drop-shadow-[0_20px_22px_rgba(255,176,1,0.12)] animate-[mediaFade_480ms_ease_both,trophyFloat_5.8s_ease-in-out_infinite] max-[1024px]:h-[360px] max-[1024px]:w-[116px] max-[560px]:h-[250px] max-[560px]:w-[82px]" src={assetPaths.trophy} alt="" width="177" height="550" decoding="async" />
    <div class="flex animate-[revealUp_760ms_both_ease] flex-col items-center text-center max-[560px]:-mt-1">
      <h1 id="hero-title" class="gold-text m-0 max-w-[770px] text-[clamp(48px,5vw,72px)] font-black leading-none max-[1024px]:text-[clamp(26px,6vw,36px)] max-[1024px]:leading-[1.05] max-[560px]:text-[23px]">Global Business<br />Excellence Awards</h1>
      <p class="mb-7 mt-8 max-w-[770px] text-[clamp(16px,1.5vw,19px)] font-normal leading-[1.6] text-gbe-muted max-[1024px]:mx-auto max-[1024px]:mb-0 max-[1024px]:mt-4 max-[1024px]:w-[var(--container)] max-[1024px]:text-[15px] max-[560px]:mt-2 max-[560px]:text-[11px] max-[560px]:leading-[1.35]">
        Celebrate achievements, honor innovation, and inspire greatness. Join us in awarding the best in
        class across multiple categories where your excellence meets recognition.
      </p>
      <a class="gold-fill inline-flex min-h-[57px] min-w-[193px] items-center justify-center gap-3 rounded-full border border-gbe-gold-deep px-7 text-[clamp(16px,1.5vw,20px)] font-bold uppercase tracking-[0.03em] text-black transition-[transform,box-shadow] duration-[220ms] hover:-translate-y-0.5 hover:bg-gbe-gold hover:text-[#070707] hover:shadow-gold-glow max-[1024px]:hidden" href="/apply">APPLY NOW <span aria-hidden="true">◎</span></a>
    </div>
    <img class="h-[450px] w-[145px] justify-self-end object-contain drop-shadow-[0_20px_22px_rgba(255,176,1,0.12)] animate-[mediaFade_480ms_ease_both,trophyFloat_5.8s_ease-in-out_infinite] [animation-delay:-2.2s] max-[1024px]:hidden" src={assetPaths.trophy} alt="" width="177" height="550" decoding="async" />
  </div>

  <SocialLinks />
</section>
