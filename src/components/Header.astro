---
import { assetPaths, navItems } from "../data/home";
---

<header class="fixed left-1/2 top-0 z-20 grid h-[150px] w-[var(--container)] -translate-x-1/2 grid-cols-[1fr_auto_1fr] items-center max-[1024px]:grid-cols-[auto_1fr_auto] max-[560px]:h-[90px] max-[560px]:w-[calc(100vw-40px)]" aria-label="Primary">
  <a class="justify-self-start translate-x-[110px] max-[1024px]:translate-x-0" href="/" aria-label="Global Business Excellence Awards home">
    <img class="h-[70px] w-[46px] animate-[mediaFade_420ms_ease_both] object-contain max-[560px]:h-[49px] max-[560px]:w-8" src={assetPaths.logo} alt="GBE Awards" width="46" height="70" decoding="async" />
  </a>

  <nav class="flex min-h-[69px] items-center gap-[18px] rounded-full border border-[rgba(255,176,1,0.72)] px-[72px] py-[11px] max-[1024px]:hidden" aria-label="Primary navigation">
    {navItems.map((item) => (
      <a class="inline-flex min-h-[45px] items-center justify-center rounded-full border border-[rgba(255,176,1,0.72)] px-[26px] text-[15px] font-bold leading-none tracking-[0.06em] text-white transition-[transform,background-color,color,box-shadow] duration-[220ms] hover:-translate-y-0.5 hover:bg-gbe-gold hover:text-[#070707] hover:shadow-gold-glow" href={item.href}>{item.label}</a>
    ))}
  </nav>

  <a class="gold-fill inline-flex min-h-[45px] items-center justify-center justify-self-end rounded-full px-7 text-[15px] font-bold leading-none tracking-[0.06em] text-[#080808] shadow-[inset_0_0_16px_rgba(255,255,255,0.16)] transition-[transform,background-color,color,box-shadow] duration-[220ms] hover:-translate-y-0.5 hover:bg-gbe-gold hover:text-[#070707] hover:shadow-gold-glow max-[1024px]:hidden" href="/apply">APPLY NOW</a>

  <button class="hidden w-7 justify-self-end gap-1 border-0 bg-transparent p-0 max-[1024px]:grid" type="button" aria-label="Open menu">
    <span class="block h-[3px] w-full rounded-full bg-gbe-gold"></span>
    <span class="block h-[3px] w-full rounded-full bg-gbe-gold"></span>
    <span class="block h-[3px] w-full rounded-full bg-gbe-gold"></span>
  </button>
</header>
