---
import { assetPaths, navItems } from "../data/home";
---

<header
  id="site-header"
  class="site-header fixed left-1/2 top-0 z-50 grid h-[130px] w-[var(--container)] -translate-x-1/2 grid-cols-[1fr_auto_1fr] items-center rounded-b-[20px] max-[1024px]:grid-cols-[auto_1fr_auto] max-[560px]:h-[90px] max-[560px]:w-[calc(100vw-40px)]"
  aria-label="Primary"
>
  <a class="justify-self-center" href="/" aria-label="Global Business Excellence Awards home">
    <img
      class="h-[64px] w-[42px] animate-[mediaFade_420ms_ease_both] object-contain max-[560px]:h-[49px] max-[560px]:w-8"
      src={assetPaths.logo}
      alt="GBE Awards"
      width="46"
      height="70"
      decoding="async"
    />
  </a>

  <div class="flex items-center gap-3 justify-self-center max-[1024px]:hidden">
    <nav
      class="desktop-nav flex min-h-[56px] items-center gap-1.5 rounded-full border border-[rgba(255,176,1,0.5)] bg-gbe-surface-3 px-3 py-2 backdrop-blur-sm"
      aria-label="Primary navigation"
    >
      {navItems.map((item) => (
        <a
          class="rounded-full px-5 py-2.5 text-[14px] font-bold uppercase tracking-[0.08em] text-gbe-text/90 transition-all duration-200 hover:bg-gbe-gold hover:text-black hover:shadow-[0_0_18px_rgba(255,176,1,0.4)]"
          href={item.href}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <button
      class="theme-toggle"
      type="button"
      aria-label="Toggle theme"
      onclick="window.__toggleTheme()"
    >
      <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z" />
      </svg>
      <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="4" />
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />
      </svg>
    </button>
  </div>

  <a
    class="btn-gold btn-gold-hover justify-self-center min-h-[48px] !px-7 !text-[14px] max-[1024px]:hidden"
    href="/contact"
  >
    Apply Now
  </a>

  <div class="flex items-center gap-2 justify-self-end max-[1024px]:flex min-[1025px]:hidden">
    <button
      class="theme-toggle"
      type="button"
      aria-label="Toggle theme"
      onclick="window.__toggleTheme()"
    >
      <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z" />
      </svg>
      <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="4" />
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />
      </svg>
    </button>
    <button
      data-menu-button
      class="grid h-11 w-11 place-items-center rounded-full border border-[rgba(255,176,1,0.42)] bg-gbe-surface-3 backdrop-blur-sm transition-colors duration-200 hover:bg-gbe-gold/10"
      type="button"
      aria-label="Open menu"
      aria-controls="mobile-menu"
      aria-expanded="false"
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" class="h-5 w-5 text-gbe-gold">
        <path data-menu-icon-open d="M4 7h16M4 12h16M4 17h16" />
        <path data-menu-icon-close class="hidden" d="M6 6l12 12M18 6 6 18" />
      </svg>
    </button>
  </div>
</header>

<div
  data-menu-scrim
  class="fixed inset-0 z-40 hidden bg-gbe-bg/45 opacity-0 backdrop-blur-[2px] transition-opacity duration-300 min-[1025px]:hidden"
  aria-hidden="true"
></div>

<nav
  id="mobile-menu"
  data-mobile-menu
  class="pointer-events-none fixed left-1/2 top-[104px] z-[60] hidden w-[min(430px,calc(100vw-32px))] -translate-x-1/2 -translate-y-3 rounded-[24px] border border-[rgba(255,176,1,0.56)] bg-gbe-surface-3/95 p-4 opacity-0 shadow-[0_28px_70px_var(--c-header-shadow),inset_0_1px_0_rgba(255,255,255,0.08)] backdrop-blur-xl transition-[opacity,transform] duration-300 min-[1025px]:hidden max-[560px]:top-[84px]"
  aria-label="Mobile navigation"
>
  <div class="rounded-[18px] border border-gbe-text/10 bg-gbe-text/[0.03] p-2">
    {navItems.map((item) => (
      <a
        class="flex items-center rounded-2xl px-4 py-3 text-[15px] font-extrabold uppercase tracking-[0.08em] text-gbe-text/90 transition-all duration-200 hover:bg-gbe-gold hover:text-black focus-visible:bg-gbe-gold focus-visible:text-black"
        href={item.href}
        data-menu-link
      >
        {item.label}
      </a>
    ))}
  </div>

  <div class="mt-4">
    <a
      class="btn-gold btn-gold-hover min-h-[52px] w-full !px-4 !text-[13px]"
      href="/contact"
      data-menu-link
    >
      Apply Now
    </a>
  </div>
</nav>

<script>
  const themeStorageKey = "gbe-theme";
  const themeDurationMs = 2 * 24 * 60 * 60 * 1000;

  window.__toggleTheme = function () {
    const html = document.documentElement;
    const current = html.getAttribute("data-theme") === "light" ? "light" : "dark";
    const next = current === "dark" ? "light" : "dark";
    html.setAttribute("data-theme", next);
    try {
      localStorage.setItem(
        themeStorageKey,
        JSON.stringify({
          theme: next,
          expiresAt: Date.now() + themeDurationMs,
        }),
      );
    } catch (_) {
      // Theme still changes for this page view when storage is unavailable.
    }
  };
</script>

<script>
  const header = document.getElementById("site-header");
  const menuButton = document.querySelector("[data-menu-button]");
  const mobileMenu = document.querySelector("[data-mobile-menu]");
  const menuScrim = document.querySelector("[data-menu-scrim]");
  const menuOpenIcon = document.querySelector("[data-menu-icon-open]");
  const menuCloseIcon = document.querySelector("[data-menu-icon-close]");

  const setMenuOpen = (open) => {
    if (!menuButton || !mobileMenu || !menuScrim || !menuOpenIcon || !menuCloseIcon) return;

    menuButton.setAttribute("aria-expanded", String(open));
    menuButton.setAttribute("aria-label", open ? "Close menu" : "Open menu");
    menuOpenIcon.classList.toggle("hidden", open);
    menuCloseIcon.classList.toggle("hidden", !open);

    if (open) {
      mobileMenu.classList.remove("hidden");
      menuScrim.classList.remove("hidden");
      document.body.classList.add("overflow-hidden");
      requestAnimationFrame(() => {
        mobileMenu.classList.remove("pointer-events-none", "opacity-0", "-translate-y-3");
        menuScrim.classList.remove("opacity-0");
      });
      return;
    }

    mobileMenu.classList.add("pointer-events-none", "opacity-0", "-translate-y-3");
    menuScrim.classList.add("opacity-0");
    document.body.classList.remove("overflow-hidden");
    window.setTimeout(() => {
      if (menuButton.getAttribute("aria-expanded") === "false") {
        mobileMenu.classList.add("hidden");
        menuScrim.classList.add("hidden");
      }
    }, 300);
  };

  if (menuButton && mobileMenu && menuScrim) {
    menuButton.addEventListener("click", () => {
      setMenuOpen(menuButton.getAttribute("aria-expanded") !== "true");
    });

    menuScrim.addEventListener("click", () => setMenuOpen(false));
    mobileMenu.querySelectorAll("[data-menu-link]").forEach((link) => {
      link.addEventListener("click", () => setMenuOpen(false));
    });

    window.addEventListener("keydown", (event) => {
      if (event.key === "Escape") setMenuOpen(false);
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth > 1024) setMenuOpen(false);
    });
  }

  if (header) {
    let ticking = false;
    const onScroll = () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          header.classList.toggle("site-header--scrolled", window.scrollY > 40);
          ticking = false;
        });
        ticking = true;
      }
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }
</script>
