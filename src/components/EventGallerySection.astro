---
const galleryImages = [
  {
    src: "/assets/gallery/leadership-award.webp",
    srcset: "/assets/gallery/leadership-award.webp 900w, /assets/gallery/leadership-award-large.webp 1440w",
    alt: "GBE Awards formal leadership award presentation on stage",
    position: "50% 42%",
  },
  {
    src: "/assets/gallery/cultural-welcome.webp",
    srcset: "/assets/gallery/cultural-welcome.webp 900w, /assets/gallery/cultural-welcome-large.webp 1440w",
    alt: "Traditional cultural welcome at the GBE Awards ceremony",
    position: "50% 48%",
  },
  {
    src: "/assets/gallery/stage-hosts.webp",
    srcset: "/assets/gallery/stage-hosts.webp 900w, /assets/gallery/stage-hosts-large.webp 1440w",
    alt: "GBE Awards hosts on stage during the ceremony",
    position: "50% 45%",
  },
  {
    src: "/assets/gallery/women-winners.webp",
    srcset: "/assets/gallery/women-winners.webp 900w, /assets/gallery/women-winners-large.webp 1440w",
    alt: "GBE Awards women winners with trophy and certificate",
    position: "52% 38%",
  },
  {
    src: "/assets/gallery/winner-certificates.webp",
    srcset: "/assets/gallery/winner-certificates.webp 900w, /assets/gallery/winner-certificates-large.webp 1440w",
    alt: "GBE Awards winners holding certificates and trophies",
    position: "50% 44%",
  },
  {
    src: "/assets/gallery/ceremony-honour.webp",
    srcset: "/assets/gallery/ceremony-honour.webp 900w, /assets/gallery/ceremony-honour-large.webp 1440w",
    alt: "GBE Awards ceremonial trophy handover",
    position: "50% 38%",
  },
  {
    src: "/assets/gallery/award-presentation.webp",
    srcset: "/assets/gallery/award-presentation.webp 900w, /assets/gallery/award-presentation-large.webp 1440w",
    alt: "GBE Awards stage award presentation with guests",
    position: "50% 43%",
  },
  {
    src: "/assets/gallery/press-wall-leaders.webp",
    srcset: "/assets/gallery/press-wall-leaders.webp 900w, /assets/gallery/press-wall-leaders-large.webp 1440w",
    alt: "GBE Awards leaders and winner at the press wall",
    position: "50% 42%",
  },
];
---

<section class="relative overflow-hidden bg-gbe-bg py-[68px] max-[560px]:py-[42px]" aria-label="Past GBE Awards event gallery">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-gbe-gold/30 to-transparent" aria-hidden="true"></div>
  <div class="container-gbe">
    <div class="event-gallery-grid">
      {galleryImages.map((image, index) => (
        <button
          type="button"
          class="event-gallery-item group"
          data-gallery-item
          data-gallery-src={image.src}
          data-gallery-srcset={image.srcset}
          data-gallery-alt={image.alt}
          data-gallery-position={image.position}
          aria-label={`Preview ${image.alt}`}
        >
          <img
            class="h-full w-full object-cover transition duration-700 ease-out"
            src={image.src}
            srcset={image.srcset}
            sizes="(max-width: 560px) 92vw, (max-width: 1024px) 44vw, 22vw"
            alt={image.alt}
            width="900"
            height={index === 0 ? "750" : "600"}
            loading="lazy"
            decoding="async"
            style={`object-position: ${image.position}`}
          />
          <span class="pointer-events-none absolute inset-0 bg-[linear-gradient(180deg,rgba(0,0,0,0.01),rgba(0,0,0,0.16))] opacity-60 transition-opacity duration-500 group-hover:opacity-35" aria-hidden="true"></span>
        </button>
      ))}
    </div>
  </div>
  <div class="event-gallery-modal" data-gallery-modal aria-hidden="true">
    <button class="event-gallery-modal-backdrop" type="button" data-gallery-close aria-label="Close gallery preview"></button>
    <div class="event-gallery-dialog" role="dialog" aria-modal="true" aria-label="Gallery image preview">
      <button class="event-gallery-close" type="button" data-gallery-close aria-label="Close gallery preview">
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
      </button>
      <img data-gallery-modal-image alt="" />
    </div>
  </div>
  <div class="pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-gbe-gold/20 to-transparent" aria-hidden="true"></div>
</section>

<style>
  .event-gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 8px;
    padding: 8px;
    border: 1px solid rgba(255, 176, 1, 0.12);
    border-radius: 18px;
    background: rgba(255, 176, 1, 0.025);
  }

  .event-gallery-item {
    position: relative;
    margin: 0;
    min-height: 0;
    padding: 0;
    overflow: hidden;
    appearance: none;
    cursor: pointer;
    border-radius: 11px;
    border: 1px solid rgba(255, 176, 1, 0.18);
    background: var(--c-card);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.26);
    transition: border-color 500ms ease, box-shadow 500ms ease;
  }

  .event-gallery-item:focus-visible {
    outline: 2px solid rgba(255, 176, 1, 0.78);
    outline-offset: 3px;
  }

  .event-gallery-item:hover {
    border-color: rgba(255, 176, 1, 0.48);
    box-shadow: 0 16px 38px rgba(0, 0, 0, 0.34);
  }

  .event-gallery-item {
    aspect-ratio: 3 / 2;
  }

  .event-gallery-dialog img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .event-gallery-modal {
    position: fixed;
    inset: 0;
    z-index: 90;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 240ms ease, visibility 240ms ease;
  }

  .event-gallery-modal.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .event-gallery-modal-backdrop {
    position: absolute;
    inset: 0;
    border: 0;
    cursor: pointer;
    background: rgba(6, 6, 8, 0.62);
    backdrop-filter: blur(18px) saturate(1.08);
  }

  .event-gallery-dialog {
    position: relative;
    z-index: 1;
    width: min(72vw, 920px);
    aspect-ratio: 3 / 2;
    padding: 10px;
    overflow: hidden;
    border: 1px solid rgba(255, 176, 1, 0.36);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.13);
    box-shadow: 0 34px 92px rgba(0, 0, 0, 0.54);
    transform: translateY(14px) scale(0.97);
    transition: transform 260ms ease;
  }

  .event-gallery-modal.is-open .event-gallery-dialog {
    transform: translateY(0) scale(1);
  }

  .event-gallery-dialog img {
    border-radius: 15px;
  }

  .event-gallery-close {
    position: absolute;
    top: 18px;
    right: 18px;
    z-index: 2;
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border: 1px solid rgba(255, 176, 1, 0.46);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.18);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.28);
    backdrop-filter: blur(16px);
  }

  .event-gallery-close span {
    position: absolute;
    width: 18px;
    height: 2px;
    border-radius: 999px;
    background: currentColor;
  }

  .event-gallery-close span:first-child {
    transform: rotate(45deg);
  }

  .event-gallery-close span:last-child {
    transform: rotate(-45deg);
  }

  .event-gallery-close:focus-visible {
    outline: 2px solid rgba(255, 176, 1, 0.78);
    outline-offset: 3px;
  }

  :global(html.event-gallery-lock),
  :global(body.event-gallery-lock) {
    overflow: hidden;
  }

  @media (max-width: 1024px) {
    .event-gallery-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .event-gallery-modal {
      padding: 26px;
    }

    .event-gallery-dialog {
      width: min(88vw, 780px);
    }
  }

  @media (max-width: 560px) {
    .event-gallery-grid {
      grid-template-columns: 1fr;
      gap: 8px;
      padding: 7px;
      border-radius: 15px;
    }

    .event-gallery-item {
      aspect-ratio: 16 / 10;
      border-radius: 9px;
      cursor: default;
      pointer-events: none;
    }

    .event-gallery-modal {
      display: none;
    }
  }
</style>

<script>
  const interactiveQuery = window.matchMedia("(min-width: 561px)");
  const items = Array.from(document.querySelectorAll<HTMLElement>("[data-gallery-item]"));
  const modal = document.querySelector<HTMLElement>("[data-gallery-modal]");
  const modalImage = document.querySelector<HTMLImageElement>("[data-gallery-modal-image]");
  const closeButtons = Array.from(document.querySelectorAll<HTMLElement>("[data-gallery-close]"));

  const readImage = (item: HTMLElement) => ({
    src: item.dataset.gallerySrc ?? "",
    srcset: item.dataset.gallerySrcset ?? "",
    alt: item.dataset.galleryAlt ?? "",
    position: item.dataset.galleryPosition ?? "50% 50%",
  });

  const assignImage = (image: HTMLImageElement | null, item: HTMLElement) => {
    if (!image) return;
    const next = readImage(item);
    image.src = next.src;
    image.srcset = next.srcset;
    image.alt = next.alt;
    image.style.objectPosition = next.position;
  };

  const openModal = (item: HTMLElement) => {
    if (!modal || !modalImage || !interactiveQuery.matches) return;
    assignImage(modalImage, item);
    modal.classList.add("is-open");
    modal.setAttribute("aria-hidden", "false");
    document.documentElement.classList.add("event-gallery-lock");
    document.body.classList.add("event-gallery-lock");
  };

  const closeModal = () => {
    modal?.classList.remove("is-open");
    modal?.setAttribute("aria-hidden", "true");
    document.documentElement.classList.remove("event-gallery-lock");
    document.body.classList.remove("event-gallery-lock");
  };

  items.forEach((item) => {
    item.addEventListener("click", () => openModal(item));
  });

  closeButtons.forEach((button) => {
    button.addEventListener("click", closeModal);
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeModal();
    }
  });

  interactiveQuery.addEventListener("change", closeModal);
</script>
