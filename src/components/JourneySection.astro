---
import { assetPaths } from "../data/home";
import JourneyImageSlider from "./JourneyImageSlider";

const journeyImages = [
  {
    src: assetPaths.journeyWinners,
    srcSet: `${assetPaths.journeyWinners} 900w, ${assetPaths.journeyWinnersLarge} 1440w`,
    alt: "GBE Awards winner receiving recognition on stage",
  },
  {
    src: assetPaths.journeyRecognition,
    srcSet: `${assetPaths.journeyRecognition} 900w, ${assetPaths.journeyRecognitionLarge} 1440w`,
    alt: "GBE Awards recipient with award presenters",
  },
  {
    src: assetPaths.journeyAwardHandover,
    srcSet: `${assetPaths.journeyAwardHandover} 900w, ${assetPaths.journeyAwardHandoverLarge} 1179w`,
    alt: "GBE Awards trophy handover ceremony",
  },
];
---

<section class="bg-gbe-surface py-20 text-center max-[560px]:pb-[78px] max-[560px]:pt-10" aria-labelledby="journey-title">
  <div class="container-gbe mb-[66px] grid grid-cols-3 gap-10 max-[1024px]:hidden">
    {journeyImages.map((image) => (
      <img class="h-[202px] w-full rounded-xl object-cover object-top" src={image.src} srcset={image.srcSet} sizes="(max-width: 1024px) 82vw, 30vw" alt={image.alt} width="900" height="600" loading="lazy" decoding="async" data-preview-image data-preview-src={image.src} data-preview-srcset={image.srcSet} data-preview-alt={image.alt} data-preview-position="50% 0%" />
    ))}
  </div>

  <div class="mb-[72px] hidden overflow-hidden max-[1024px]:block max-[560px]:mb-[64px]">
    <JourneyImageSlider images={journeyImages} client:visible />
  </div>
  <h2 id="journey-title" class="gold-text mx-auto mb-7 mt-0 animate-[revealUp_760ms_both_ease] text-[clamp(32px,3vw,40px)] font-black leading-[1.1]">Your Journey to Recognition Starts Here</h2>
  <p class="container-gbe mb-[55px] animate-[revealUp_760ms_both_ease] text-[clamp(15px,1.3vw,18px)] font-normal leading-[1.7] text-gbe-muted max-[1024px]:text-[15px]">
    Join a prestigious community of achievers spanning London, Colombo, and beyond. Whether you are a startup
    founder, a corporate leader, or a social entrepreneur, GBE Awards 2026 is your platform to gain
    international recognition, build cross-border partnerships, and leave a lasting legacy on the global
    business stage.
  </p>
  <a class="btn-gold btn-gold-hover" href="https://wa.link/4f21fy" target="_blank" rel="noopener noreferrer">Apply Now</a>
</section>
