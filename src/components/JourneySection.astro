---
import { assetPaths } from "../data/home";
---

<section class="journey-section" aria-labelledby="journey-title">
  <div class="journey-media">
    <img src={assetPaths.interview} alt="Interview" width="768" height="419" loading="lazy" decoding="async" />
    <img src={assetPaths.awardInHand} alt="Award in hand" width="768" height="419" loading="lazy" decoding="async" />
    <img src={assetPaths.redCarpet} alt="Red carpet night city" width="768" height="512" loading="lazy" decoding="async" />
  </div>
  <h2 id="journey-title" class="journey-title reveal">Your Journey to Recognition Starts Here</h2>
  <p class="journey-copy reveal">
    Join a prestigious community of achievers, be acknowledged for your hard work, and inspire others with
    your story. GBE Awards 2025 is more than an award. It’s a platform to amplify your achievements and leave a
    lasting legacy on the global stage.
  </p>
  <a class="outline-button" href="/apply" aria-label="Apply now"></a>
</section>
