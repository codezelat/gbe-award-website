---
import { CategorySlider } from "./LoopSliders";
---

<section class="bg-gbe-bg py-20 text-center max-[560px]:py-[70px]" aria-labelledby="categories-title">
  <div class="animate-[revealUp_760ms_both_ease]">
    <h2 id="categories-title" class="gold-text m-0 text-[clamp(31px,3vw,40px)] font-black leading-[1.1] max-[560px]:text-[clamp(22px,6vw,28px)]">Awards Across Diverse Categories</h2>
    <p class="mx-auto mb-0 mt-[25px] max-w-[980px] text-[clamp(15px,1.3vw,18px)] font-normal leading-[1.6] text-gbe-muted max-[560px]:mt-0 max-[560px]:w-[var(--container)] max-[560px]:text-sm">
      From finance, technology, and media to healthcare, sustainability, and social enterprise, GBE Awards spans sixteen categories that celebrate excellence across every sector in the UK, Sri Lanka, and worldwide.
    </p>
  </div>

  <CategorySlider client:visible />
</section>
