---
import { assetPaths, digitalMagazine } from "../data/home";
---

<section class="relative overflow-hidden bg-gbe-bg py-[72px] max-[560px]:py-[48px]" aria-labelledby="digital-magazine-title">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-gbe-gold/24 to-transparent" aria-hidden="true"></div>
  <div class="container-gbe">
    <div class="magazine-shell">
      <div class="magazine-copy">
        <p class="magazine-eyebrow">Digital magazine</p>
        <h2 id="digital-magazine-title" class="gold-text text-[clamp(32px,4vw,54px)] font-black leading-[0.98]">
          {digitalMagazine.title}
        </h2>
        <p class="magazine-description">{digitalMagazine.description}</p>
        <div class="magazine-actions">
          <a class="btn-gold btn-gold-hover inline-flex items-center justify-center rounded-full px-7 py-3 text-sm font-black uppercase tracking-[0.18em] text-black" href={digitalMagazine.url} target="_blank" rel="noopener noreferrer" aria-label="Read the GBE Awards 2025 digital magazine">
            Read digital magazine
          </a>
          <span class="magazine-meta" aria-label="Magazine format">Interactive flipbook · 84 pages</span>
        </div>
      </div>

      <a class="magazine-visual group" href={digitalMagazine.url} target="_blank" rel="noopener noreferrer" aria-label="Open the GBE Awards 2025 digital magazine">
        <span class="magazine-visual-glow" aria-hidden="true"></span>
        <img
          class="relative z-[1] h-auto w-full transition duration-700 ease-out group-hover:scale-[1.018]"
          src={assetPaths.magazineMockup}
          alt="GBE Awards digital magazine mockup showing the real front cover and final page"
          width="1536"
          height="1024"
          loading="lazy"
          decoding="async"
        />
      </a>
    </div>
  </div>
  <div class="pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-gbe-gold/20 to-transparent" aria-hidden="true"></div>
</section>

<style>
  .magazine-shell {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(0, 1.18fr);
    align-items: center;
    gap: clamp(28px, 5vw, 64px);
    border: 1px solid rgba(255, 176, 1, 0.14);
    border-radius: 22px;
    padding: clamp(24px, 4vw, 44px);
    background:
      linear-gradient(135deg, rgba(255, 176, 1, 0.09), transparent 34%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.055), rgba(255, 255, 255, 0.02)),
      var(--c-card);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.26);
  }

  .magazine-copy {
    min-width: 0;
  }

  .magazine-eyebrow {
    margin: 0 0 14px;
    color: var(--c-gold);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .magazine-description {
    margin: 22px 0 0;
    max-width: 58ch;
    color: var(--c-muted);
    font-size: clamp(16px, 1.25vw, 18px);
    font-weight: 500;
    line-height: 1.75;
  }

  .magazine-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 14px 18px;
    margin-top: 30px;
  }

  .magazine-meta {
    color: var(--c-soft);
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .magazine-visual {
    position: relative;
    display: block;
    min-width: 0;
    border-radius: 18px;
    outline: none;
    isolation: isolate;
  }

  .magazine-visual:focus-visible {
    outline: 2px solid rgba(255, 176, 1, 0.8);
    outline-offset: 5px;
  }

  .magazine-visual-glow {
    position: absolute;
    inset: 12% 8% 4%;
    z-index: 0;
    border-radius: 999px;
    background: rgba(255, 176, 1, 0.16);
    filter: blur(34px);
    opacity: 0.75;
    transition: opacity 600ms ease, transform 600ms ease;
  }

  .magazine-visual:hover .magazine-visual-glow {
    opacity: 1;
    transform: scale(1.04);
  }

  @media (max-width: 1024px) {
    .magazine-shell {
      grid-template-columns: 1fr;
      gap: 26px;
    }

    .magazine-copy {
      max-width: 720px;
    }

    .magazine-visual {
      max-width: 760px;
      margin-inline: auto;
    }
  }

  @media (max-width: 560px) {
    .magazine-shell {
      border-radius: 17px;
      padding: 20px;
    }

    .magazine-description {
      line-height: 1.65;
    }

    .magazine-actions {
      align-items: stretch;
    }

    .magazine-actions .btn-gold {
      width: 100%;
      min-height: 48px;
      padding-inline: 16px;
      letter-spacing: 0.12em;
    }

    .magazine-meta {
      width: 100%;
      text-align: center;
      font-size: 12px;
    }
  }
</style>
