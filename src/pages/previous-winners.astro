---
import "../styles/global.css";
import ThemeInit from "../components/ThemeInit.astro";
import Header from "../components/Header.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { assetPaths } from "../data/home";
import { getPublicWinners } from "../lib/public-content";

export const prerender = false;

const title = "Previous Winners | Global Business Excellence Awards";
const description =
  "Celebrating the past winners of the Global Business Excellence Awards. Discover the companies and leaders who set the benchmark for excellence across industries.";

Astro.response.headers.set("cache-control", "public, s-maxage=60, stale-while-revalidate=300");
const winners = await getPublicWinners();
---

<!doctype html>
<html lang="en">
  <head>
    <ThemeInit />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://gbeaward.com/previous-winners" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <link rel="icon" type="image/png" href="/assets/brand/favicon-32.png" />
    <link rel="apple-touch-icon" href="/assets/brand/apple-touch-icon.png" />
    <title>{title}</title>
  </head>
  <body>
    <div class="min-h-screen animate-[pageFade_420ms_ease_both] bg-[var(--c-page-glow)]">
      <Header />
      <main class="bg-[radial-gradient(circle_at_50%_0%,rgba(224,176,60,0.08),transparent_420px),var(--c-bg)] pt-[210px] pb-24 max-[1024px]:pt-[160px] max-[560px]:pt-[130px] max-[560px]:pb-14">
        <div class="container-gbe">

          <!-- Hero -->
          <div class="mb-14 text-center max-[560px]:mb-10">
            <div class="mb-6 flex items-center justify-center gap-4 max-[560px]:mb-4">
              <div class="h-[1px] w-16 bg-gradient-to-r from-transparent to-gbe-gold/50"></div>
              <span class="text-xs font-black uppercase tracking-[0.2em] text-gbe-gold-soft">Hall of Excellence</span>
              <div class="h-[1px] w-16 bg-gradient-to-l from-transparent to-gbe-gold/50"></div>
            </div>
            <h1 class="gold-text mb-4 text-[clamp(36px,5vw,56px)] font-black leading-none max-[560px]:text-[28px]">Previous Winners</h1>
            <p class="mx-auto max-w-[680px] text-[clamp(16px,1.4vw,19px)] font-normal leading-[1.7] text-gbe-muted max-[560px]:text-[15px]">
              Celebrating the outstanding companies, entrepreneurs, and leaders who earned the Global Business
              Excellence Award. Each winner represents the pinnacle of achievement in their field.
            </p>
          </div>

          <!-- Winner cards grid -->
          {winners.length > 0 ? (
            <div class="grid grid-cols-3 gap-7 max-[1024px]:grid-cols-2 max-[560px]:grid-cols-1">
              {winners.map((winner, i) => (
                <article
                  class="winner-card group relative overflow-hidden rounded-[16px] border border-[rgba(255,176,1,0.3)] bg-gbe-card shadow-[var(--c-card-shadow)] transition-all duration-500 hover:border-gbe-gold hover:shadow-[0_20px_60px_rgba(255,176,1,0.22)]"
                  style={`animation-delay:${i * 80}ms`}
                >
                  <div class="pointer-events-none absolute inset-0 z-[5] bg-gradient-to-r from-transparent via-[rgba(255,176,1,0.07)] to-transparent opacity-0 transition-all duration-700 group-hover:translate-x-full group-hover:opacity-100"></div>
                  <div class="pointer-events-none absolute -left-20 -top-20 h-40 w-40 rounded-full bg-[radial-gradient(circle,rgba(255,176,1,0.12),transparent_70%)] opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
                  <div class="pointer-events-none absolute -bottom-20 -right-20 h-40 w-40 rounded-full bg-[radial-gradient(circle,rgba(255,176,1,0.1),transparent_70%)] opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>

                  <div class="relative overflow-hidden px-6 pt-7">
                    <div class="relative mx-auto mb-5 w-fit">
                      <div class="absolute -inset-[5px] rounded-full bg-[conic-gradient(from_0deg,#6a4c1a,#ffd05a,#6a4c1a)] opacity-50 blur-[3px] transition-opacity duration-500 group-hover:opacity-100 group-hover:[animation:spin_4s_linear_infinite]"></div>
                      <div class="absolute -inset-[1px] rounded-full bg-[conic-gradient(from_0deg,#6a4c1a,#ffd05a,#6a4c1a)] opacity-60"></div>
                      <img class="relative h-24 w-24 rounded-full border-2 border-[var(--c-surface-3)] object-cover object-center transition-transform duration-500 group-hover:scale-110" src={winner.image} alt={winner.name} width="300" height="300" loading="lazy" decoding="async" />
                      <div class="gold-fill absolute -bottom-1 -right-1 grid h-8 w-8 place-items-center rounded-full border-2 border-[var(--c-surface-3)] shadow-[0_2px_12px_rgba(255,176,1,0.4)]">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="h-4 w-4 text-black">
                          <path d="M5 12l4 4L19 6" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                      </div>
                    </div>

                    <div class="mx-auto mb-4 flex w-fit items-center gap-2 rounded-full border border-[rgba(255,176,1,0.35)] bg-gbe-surface-3 px-4 py-1.5">
                      <img class="h-3.5 w-3.5 object-contain" src={assetPaths.award} alt="" width="52" height="52" loading="lazy" decoding="async" />
                      <span class="text-[10px] font-black uppercase tracking-[0.15em] text-gbe-gold-soft">Award Winner</span>
                    </div>
                  </div>

                  <div class="relative z-[1] px-6 pb-6 text-center">
                    <h2 class="m-0 text-[clamp(16px,1.3vw,19px)] font-bold leading-[1.3] text-gbe-text transition-colors duration-300 group-hover:text-gbe-gold">{winner.title}</h2>
                    <p class="mb-5 mt-2 text-sm font-normal leading-[1.5] text-gbe-muted">{winner.name}</p>
                    {winner.market ? <p class="mb-5 mt-[-12px] text-xs font-bold uppercase tracking-[0.12em] text-gbe-gold-soft">{winner.market} · {winner.year}</p> : null}

                    <div class="relative mb-4">
                      <div class="h-[1px] bg-gradient-to-r from-transparent via-[rgba(255,176,1,0.2)] to-transparent"></div>
                      <div class="gold-fill absolute left-1/2 top-1/2 grid h-7 w-7 -translate-x-1/2 -translate-y-1/2 place-items-center rounded-full border border-[rgba(255,176,1,0.5)]">
                        <img class="h-4 w-4 object-contain" src={assetPaths.award} alt="" width="52" height="52" loading="lazy" decoding="async" />
                      </div>
                    </div>

                    <span class="font-script text-3xl font-bold leading-[0.9] text-gbe-text/70 transition-colors duration-300 group-hover:text-gbe-gold-soft">Awarded</span>
                  </div>
                </article>
              ))}
            </div>
          ) : (
            <div class="rounded-[18px] border border-[rgba(255,176,1,0.18)] bg-[radial-gradient(circle_at_50%_50%,rgba(255,176,1,0.06),transparent),var(--c-card)] px-8 py-10 text-center shadow-[var(--c-card-shadow)] max-[560px]:px-6 max-[560px]:py-8">
              <p class="text-sm font-bold uppercase tracking-[0.16em] text-gbe-gold-soft">No winners published yet</p>
              <p class="mx-auto mt-3 max-w-[620px] text-[clamp(15px,1.15vw,17px)] font-normal leading-[1.7] text-gbe-muted">
                Winner profiles will appear here automatically once they are published in the awards database.
              </p>
            </div>
          )}

          <!-- CTA -->
          <div class="mt-16 text-center max-[560px]:mt-10">
            <div class="mx-auto max-w-[800px] rounded-[18px] border border-[rgba(255,176,1,0.42)] bg-[radial-gradient(circle_at_50%_50%,rgba(255,176,1,0.06),transparent),var(--c-card)] px-10 py-14 shadow-[var(--c-card-shadow)] max-[560px]:rounded-[14px] max-[560px]:px-7 max-[560px]:py-10">
              <h2 class="gold-text mb-4 mt-0 text-[clamp(24px,3vw,34px)] font-black leading-tight">Join the Hall of Excellence</h2>
              <p class="mx-auto mb-8 max-w-[500px] text-[clamp(15px,1.2vw,17px)] font-normal leading-[1.7] text-gbe-muted max-[560px]:text-sm">
                Could your organisation be our next award winner? Apply today and earn your place among the
                most respected names in global business.
              </p>
              <a class="btn-gold btn-gold-hover" href="/contact">Apply Now</a>
            </div>
          </div>

        </div>
      </main>
      <SiteFooter />
    </div>
  </body>
</html>
