---
import "../styles/global.css";
import ThemeInit from "../components/ThemeInit.astro";
import SeoHead from "../components/SeoHead.astro";
import Header from "../components/Header.astro";
import SiteFooter from "../components/SiteFooter.astro";
import WinnerStoryCard from "../components/WinnerStoryCard.astro";
import { assetPaths } from "../data/home";
import { setPublicResponseCache } from "../lib/http-cache";
import { buildBreadcrumbSchema, buildItemListSchema, buildPageSchema, normalizeDescription } from "../lib/seo";
import { getWinnerDirectory } from "../lib/winners/queries";

export const prerender = false;

const title = "Previous Winners | Global Business Excellence Awards";
const description =
  "Celebrating the past winners of the Global Business Excellence Awards. Discover the companies and leaders who set the benchmark for excellence across industries.";

setPublicResponseCache(Astro.response.headers);
const page = Number(Astro.url.searchParams.get("page") || "1");
const directory = await getWinnerDirectory({ page, limit: 24 });
const winners = directory.winners;
const winnerSummary = winners
  .slice(0, 10)
  .map((winner) => ({
    name: `${winner.recipientName} - ${winner.displayAwardTitle || winner.awardTitle}`,
    url: winner.storyPath,
    image: winner.imageUrl || assetPaths.trophy,
    description: normalizeDescription(
      winner.standfirst?.trim() ||
        winner.awardCitation?.trim() ||
        `${winner.recipientName} is featured among Global Business Excellence Awards winners.`,
    ),
  }));
---

<!doctype html>
<html lang="en">
  <head>
    <ThemeInit />
    <SeoHead
      title={title}
      description={description}
      path="/previous-winners"
      image={winners[0]?.imageUrl || assetPaths.trophy}
      schema={[
        buildPageSchema({
          path: "/previous-winners",
          title,
          description,
          pageType: "CollectionPage",
          image: winners[0]?.imageUrl || assetPaths.trophy,
        }),
        buildBreadcrumbSchema([
          { name: "Home", path: "/" },
          { name: "Previous Winners", path: "/previous-winners" },
        ]),
        ...(winnerSummary.length > 0
          ? [
              buildItemListSchema({
                path: "/previous-winners",
                title: "Global Business Excellence Awards previous winners",
                items: winnerSummary,
              }),
            ]
          : []),
      ]}
    />
  </head>
  <body>
    <div class="min-h-screen animate-[pageFade_420ms_ease_both] bg-[var(--c-page-glow)]">
      <Header />
      <main class="bg-[radial-gradient(circle_at_50%_0%,rgba(224,176,60,0.08),transparent_420px),var(--c-bg)] pt-[210px] pb-24 max-[1024px]:pt-[160px] max-[560px]:pt-[130px] max-[560px]:pb-14">
        <div class="container-gbe">

          <!-- Hero -->
          <div class="mb-14 text-center max-[560px]:mb-10">
            <div class="mb-6 flex items-center justify-center gap-4 max-[560px]:mb-4">
              <div class="h-[1px] w-16 bg-gradient-to-r from-transparent to-gbe-gold/50"></div>
              <span class="text-xs font-black uppercase tracking-[0.2em] text-gbe-gold-soft">Hall of Excellence</span>
              <div class="h-[1px] w-16 bg-gradient-to-l from-transparent to-gbe-gold/50"></div>
            </div>
            <h1 class="gold-text mb-4 text-[clamp(36px,5vw,56px)] font-black leading-none max-[560px]:text-[28px]">Previous Winners</h1>
            <p class="mx-auto max-w-[680px] text-[clamp(16px,1.4vw,19px)] font-normal leading-[1.7] text-gbe-muted max-[560px]:text-[15px]">
              Celebrating the outstanding companies, entrepreneurs, and leaders who earned the Global Business
              Excellence Award. Each winner represents the pinnacle of achievement in their field.
            </p>
          </div>

          <!-- Winner cards grid -->
          {winners.length > 0 ? (
            <div class="grid grid-cols-3 gap-7 max-[1024px]:grid-cols-2 max-[560px]:grid-cols-1">
              {winners.map((winner, i) => <WinnerStoryCard winner={winner} index={i} />)}
            </div>
          ) : (
            <div class="rounded-[18px] border border-[rgba(255,176,1,0.18)] bg-[radial-gradient(circle_at_50%_50%,rgba(255,176,1,0.06),transparent),var(--c-card)] px-8 py-10 text-center shadow-[var(--c-card-shadow)] max-[560px]:px-6 max-[560px]:py-8">
              <p class="text-sm font-bold uppercase tracking-[0.16em] text-gbe-gold-soft">No winners published yet</p>
              <p class="mx-auto mt-3 max-w-[620px] text-[clamp(15px,1.15vw,17px)] font-normal leading-[1.7] text-gbe-muted">
                Winner profiles will appear here automatically once they are published in the awards database.
              </p>
            </div>
          )}

          {directory.pages > 1 ? (
            <nav class="mt-12 flex flex-wrap items-center justify-center gap-3" aria-label="Previous winners pages">
              {directory.page > 1 ? (
                <a class="rounded-full border border-[rgba(255,176,1,0.3)] px-5 py-2 text-sm font-bold text-gbe-text no-underline transition-colors hover:border-gbe-gold hover:text-gbe-gold" href={`/previous-winners?page=${directory.page - 1}`}>Previous</a>
              ) : null}
              <span class="text-sm font-bold text-gbe-muted">Page {directory.page} of {directory.pages}</span>
              {directory.page < directory.pages ? (
                <a class="rounded-full border border-[rgba(255,176,1,0.3)] px-5 py-2 text-sm font-bold text-gbe-text no-underline transition-colors hover:border-gbe-gold hover:text-gbe-gold" href={`/previous-winners?page=${directory.page + 1}`}>Next</a>
              ) : null}
            </nav>
          ) : null}

          <!-- CTA -->
          <div class="mt-16 text-center max-[560px]:mt-10">
            <div class="mx-auto max-w-[800px] rounded-[18px] border border-[rgba(255,176,1,0.42)] bg-[radial-gradient(circle_at_50%_50%,rgba(255,176,1,0.06),transparent),var(--c-card)] px-10 py-14 shadow-[var(--c-card-shadow)] max-[560px]:rounded-[14px] max-[560px]:px-7 max-[560px]:py-10">
              <h2 class="gold-text mb-4 mt-0 text-[clamp(24px,3vw,34px)] font-black leading-tight">Join the Hall of Excellence</h2>
              <p class="mx-auto mb-8 max-w-[500px] text-[clamp(15px,1.2vw,17px)] font-normal leading-[1.7] text-gbe-muted max-[560px]:text-sm">
                Could your organisation be our next award winner? Apply today and earn your place among the
                most respected names in global business.
              </p>
              <a class="btn-gold btn-gold-hover" href="https://access.gbeaward.com/apply" target="_blank">Apply Now</a>
            </div>
          </div>

        </div>
      </main>
      <SiteFooter />
    </div>
  </body>
</html>
