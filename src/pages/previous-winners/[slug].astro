---
import "../../styles/global.css";
import ThemeInit from "../../components/ThemeInit.astro";
import SeoHead from "../../components/SeoHead.astro";
import Header from "../../components/Header.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import WinnerStoryArticle from "../../components/WinnerStoryArticle.astro";
import { assetPaths } from "../../data/home";
import { normalizeDescription } from "../../lib/seo";
import { getRelatedWinners, resolveWinnerSlug } from "../../lib/winners/queries";
import { buildWinnerArticleSchema } from "../../lib/winners/seo";

export const prerender = false;

const slug = Astro.params.slug;

if (!slug) {
  return Astro.redirect("/previous-winners", 302);
}

const resolved = await resolveWinnerSlug(slug);

if (!resolved) {
  return new Response(null, { status: 404 });
}

const { winner, redirect } = resolved;

if (redirect && winner.slug) {
  return Astro.redirect(`/previous-winners/${winner.slug}`, 301);
}

Astro.response.headers.set("cache-control", "public, s-maxage=300, stale-while-revalidate=86400");

const related = await getRelatedWinners(winner, 3);
const title = winner.seoTitle || winner.headline || `${winner.recipientName} wins ${winner.awardTitle}`;
const description = normalizeDescription(
  winner.seoDescription ||
    winner.standfirst ||
    winner.awardCitation ||
    `${winner.recipientName} is recognised as a Global Business Excellence Awards winner for ${winner.awardTitle}.`,
);
const path = `/previous-winners/${winner.slug}`;
const image = winner.socialImageUrl || winner.heroImageUrl || winner.imageUrl || assetPaths.trophy;
const noindex = winner.indexingStatus !== "index";

if (noindex) {
  Astro.response.headers.set("x-robots-tag", "noindex, follow");
}
---

<!doctype html>
<html lang="en">
  <head>
    <ThemeInit />
    <SeoHead
      title={title}
      description={description}
      path={path}
      image={image}
      type="article"
      noindex={noindex}
      publishedTime={winner.publishedAt || undefined}
      modifiedTime={winner.contentUpdatedAt || winner.publishedAt || undefined}
      authorName={winner.authorName || undefined}
      schema={buildWinnerArticleSchema({ winner, path, title, description, image })}
    />
  </head>
  <body>
    <div class="min-h-screen animate-[pageFade_420ms_ease_both] bg-[var(--c-page-glow)]">
      <Header />
      <main class="bg-[radial-gradient(circle_at_50%_0%,rgba(224,176,60,0.08),transparent_420px),var(--c-bg)] pb-24 pt-[190px] max-[1024px]:pt-[150px] max-[560px]:pb-14 max-[560px]:pt-[120px]">
        <WinnerStoryArticle winner={winner} related={related} />
      </main>
      <SiteFooter />
    </div>
  </body>
</html>
