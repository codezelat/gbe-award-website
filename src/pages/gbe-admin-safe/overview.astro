---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import { getDashboardStats } from "../../lib/admin/content";

const stats = await getDashboardStats();

const cards = [
  {
    label: "Past winners",
    value: stats.winners.total,
    detail: `${stats.winners.published} published`,
    action: "Manage winners",
    href: "/gbe-admin-safe/winners",
    accent: "bg-[#ffb001]/10 text-[#ffd05a] ring-[#ffb001]/20",
    icon: "M6 9H4.5a2.5 2.5 0 0 1 0-5H6m12 5h1.5a2.5 2.5 0 0 0 0-5H18M6 4v6a6 6 0 0 0 12 0V4M8 4h8M9 20h6M12 14v6",
  },
  {
    label: "Nominations",
    value: stats.nominations.total,
    detail: `${stats.nominations.submitted} submitted`,
    action: "Review nominations",
    href: "/gbe-admin-safe/nominations",
    accent: "bg-sky-400/10 text-sky-300 ring-sky-400/20",
    icon: "M15.562 12.43a4 4 0 1 0-7.124 0l-1.438 4.29a1 1 0 0 0 .95 1.32h8.1a1 1 0 0 0 .95-1.32zM12 9a2 2 0 1 0 0-4 2 2 0 0 0 0 4zM8.5 20h7M12 17v3",
  },
];
---

<AdminLayout activeView="overview" pageTitle="Overview" crumb="Dashboard">
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-bold tracking-tight text-zinc-50">Dashboard</h1>
      <p class="mt-1 text-sm text-zinc-500">Pick up the work that needs your attention.</p>
    </div>

    <div class="grid grid-cols-2 gap-4 max-[560px]:grid-cols-1">
      {
        cards.map((card) => (
          <a href={card.href} class="group rounded-2xl border border-white/[0.06] bg-[#101013] p-5 transition-all hover:border-white/[0.12] hover:bg-[#131316] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#ffb001]/40">
            <div class:list={["grid size-10 place-items-center rounded-xl ring-1 ring-inset", card.accent]}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d={card.icon} />
              </svg>
            </div>
            <p class="mt-4 text-3xl font-bold tracking-tight text-zinc-50">{card.value}</p>
            <p class="mt-1 text-sm font-medium text-zinc-300">{card.label}</p>
            <p class="mt-0.5 text-[13px] text-zinc-500">{card.detail}</p>
            <span class="mt-5 inline-flex items-center gap-1.5 text-[13px] font-medium text-zinc-400 transition group-hover:text-zinc-100">
              {card.action}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14M13 6l6 6-6 6" />
              </svg>
            </span>
          </a>
        ))
      }
    </div>
  </div>
</AdminLayout>
