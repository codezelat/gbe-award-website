---
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import { getDashboardStats } from "../../lib/admin/content";

const stats = await getDashboardStats();

const cards = [
  {
    label: "Past winners",
    value: stats.winners.total,
    detail: `${stats.winners.published} published`,
    accent: "bg-[#ffb001]/10 text-[#ffd05a] ring-[#ffb001]/20",
    icon: "M6 9H4.5a2.5 2.5 0 0 1 0-5H6m12 5h1.5a2.5 2.5 0 0 0 0-5H18M6 4v6a6 6 0 0 0 12 0V4M8 4h8M9 20h6M12 14v6",
  },
  {
    label: "Nominations",
    value: stats.nominations.total,
    detail: `${stats.nominations.submitted} submitted`,
    accent: "bg-sky-400/10 text-sky-300 ring-sky-400/20",
    icon: "M15.562 12.43a4 4 0 1 0-7.124 0l-1.438 4.29a1 1 0 0 0 .95 1.32h8.1a1 1 0 0 0 .95-1.32zM12 9a2 2 0 1 0 0-4 2 2 0 0 0 0 4zM8.5 20h7M12 17v3",
  },
];
---

<AdminLayout activeView="overview" pageTitle="Overview" crumb="Dashboard">
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-bold tracking-tight text-zinc-50">Dashboard</h1>
      <p class="mt-1 text-sm text-zinc-500">A snapshot of your award content across all markets.</p>
    </div>

    <div class="grid grid-cols-2 gap-4 max-[560px]:grid-cols-1">
      {
        cards.map((card) => (
          <div class="rounded-2xl border border-white/[0.06] bg-[#101013] p-5 transition-colors hover:border-white/[0.1]">
            <div class:list={["grid size-10 place-items-center rounded-xl ring-1 ring-inset", card.accent]}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d={card.icon} />
              </svg>
            </div>
            <p class="mt-4 text-3xl font-bold tracking-tight text-zinc-50">{card.value}</p>
            <p class="mt-1 text-sm font-medium text-zinc-300">{card.label}</p>
            <p class="mt-0.5 text-[13px] text-zinc-500">{card.detail}</p>
          </div>
        ))
      }
    </div>

    <div class="grid gap-4 lg:grid-cols-2">
      <a
        href="/gbe-admin-safe/winners"
        class="group flex items-center justify-between gap-4 rounded-2xl border border-white/[0.06] bg-[#101013] p-5 transition-all hover:border-[#ffb001]/25 hover:bg-[#131316]"
      >
        <div class="flex items-center gap-4">
          <div class="grid size-11 place-items-center rounded-xl bg-[#ffb001]/10 text-[#ffd05a] ring-1 ring-inset ring-[#ffb001]/20">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6m12 5h1.5a2.5 2.5 0 0 0 0-5H18M6 4v6a6 6 0 0 0 12 0V4M8 4h8M9 20h6M12 14v6" />
            </svg>
          </div>
          <div>
            <p class="font-semibold text-zinc-100">Manage past winners</p>
            <p class="mt-0.5 text-[13px] text-zinc-500">Create, edit, and publish winner profiles</p>
          </div>
        </div>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-zinc-600 transition group-hover:text-[#ffd05a]">
          <path d="M7 17 17 7M7 7h10v10" />
        </svg>
      </a>

      <a
        href="/gbe-admin-safe/nominations"
        class="group flex items-center justify-between gap-4 rounded-2xl border border-white/[0.06] bg-[#101013] p-5 transition-all hover:border-sky-400/25 hover:bg-[#131316]"
      >
        <div class="flex items-center gap-4">
          <div class="grid size-11 place-items-center rounded-xl bg-sky-400/10 text-sky-300 ring-1 ring-inset ring-sky-400/20">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15.562 12.43a4 4 0 1 0-7.124 0l-1.438 4.29a1 1 0 0 0 .95 1.32h8.1a1 1 0 0 0 .95-1.32zM12 9a2 2 0 1 0 0-4 2 2 0 0 0 0 4zM8.5 20h7M12 17v3" />
            </svg>
          </div>
          <div>
            <p class="font-semibold text-zinc-100">Review nominations</p>
            <p class="mt-0.5 text-[13px] text-zinc-500">Shortlist and publish incoming nominees</p>
          </div>
        </div>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-zinc-600 transition group-hover:text-sky-300">
          <path d="M7 17 17 7M7 7h10v10" />
        </svg>
      </a>
    </div>
  </div>
</AdminLayout>
