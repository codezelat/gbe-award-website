---
import "../styles/global.css";
import ThemeInit from "../components/ThemeInit.astro";
import SeoHead from "../components/SeoHead.astro";
import Header from "../components/Header.astro";
import HeroSection from "../components/HeroSection.astro";
import AboutSection from "../components/AboutSection.astro";
import CategoriesSection from "../components/CategoriesSection.astro";
import JourneySection from "../components/JourneySection.astro";
import NomineesSection from "../components/NomineesSection.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { assetPaths, seo } from "../data/home";
import { buildEventSchema, buildPageSchema } from "../lib/seo";
---

<!doctype html>
<html lang="en">
  <head>
    <ThemeInit />
    <SeoHead
      title={seo.title}
      description={seo.description}
      keywords={seo.keywords}
      path="/"
      image={assetPaths.trophy}
      schema={[
        buildPageSchema({
          path: "/",
          title: seo.title,
          description: seo.description,
          image: assetPaths.trophy,
        }),
        buildEventSchema(),
      ]}
    />
    <link rel="manifest" href="/site.webmanifest" />
  </head>
  <body>
    <div class="min-h-screen animate-[pageFade_420ms_ease_both] bg-[var(--c-page-glow)]">
      <Header />
      <main>
        <HeroSection />
        <AboutSection />
        <CategoriesSection />
        <JourneySection />
        <NomineesSection />
      </main>
      <SiteFooter />
    </div>
  </body>
</html>
