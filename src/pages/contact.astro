---
import "../styles/global.css";
import ThemeInit from "../components/ThemeInit.astro";
import Header from "../components/Header.astro";
import SocialLinks from "../components/SocialLinks";
import SiteFooter from "../components/SiteFooter.astro";
import { assetPaths } from "../data/home";

const title = "Contact GBE Awards | Global Business Excellence Awards 2026";
const description =
  "Get in touch with the Global Business Excellence Awards team. Whether you want to nominate, apply, partner, or learn more, we are here to help.";

const contactInfo = [
  {
    label: "Organised By",
    value: "London Business Consultancy",
    icon: `<path d="M3 21h18M5 21V7l8-4v18M19 21V11l-6-4" stroke-linejoin="round"/>`,
  },
  {
    label: "Based In",
    value: "London, United Kingdom",
    icon: `<path d="M12 2C8 2 5 5 5 9c0 5 7 13 7 13s7-8 7-13c0-4-3-7-7-7z" stroke-linejoin="round"/><circle cx="12" cy="9" r="2.5"/>`,
  },
  {
    label: "Email",
    value: "info@gbeaward.com",
    href: "mailto:info@gbeaward.com",
    icon: `<path d="M3 8l9 6 9-6M3 8v10h18V8M3 8l9-5 9 5" stroke-linejoin="round"/>`,
  },
  {
    label: "WhatsApp",
    value: "Chat with us",
    href: "https://wa.link/10p065",
    icon: `<path d="M4.7 19.4 6 15.6a7.4 7.4 0 1 1 2.7 2.7l-4 1.1Z" stroke-linejoin="round"/><path d="M9.2 8.6c.2-.4.4-.4.7-.4h.5c.2 0 .4 0 .5.4l.6 1.4c.1.3 0 .5-.2.7l-.4.4c.6 1 1.3 1.8 2.4 2.3l.5-.5c.2-.2.4-.3.7-.1l1.4.7c.3.1.4.3.3.6-.1.6-.8 1.5-1.4 1.5-2.6 0-6.2-3.1-6.2-6 0-.3.1-.5.1-.6Z" stroke-linejoin="round"/>`,
  },
];

const reasons = [
  { title: "Nominate", desc: "Nominate a company, entrepreneur, or leader for a GBE Award." },
  { title: "Apply", desc: "Submit your own organisation for consideration across our 16 categories." },
  { title: "Partner", desc: "Explore sponsorship, media, or strategic partnership opportunities." },
  { title: "Press", desc: "Media enquiries, interviews, and press kit requests." },
];
---

<!doctype html>
<html lang="en">
  <head>
    <ThemeInit />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://gbeaward.com/contact" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <link rel="icon" type="image/png" href="/assets/brand/favicon-32.png" />
    <link rel="apple-touch-icon" href="/assets/brand/apple-touch-icon.png" />
    <title>{title}</title>
  </head>
  <body>
    <div class="min-h-screen animate-[pageFade_420ms_ease_both] bg-[var(--c-page-glow)]">
      <Header />
      <main class="bg-[radial-gradient(circle_at_50%_0%,rgba(224,176,60,0.08),transparent_420px),var(--c-bg)] pt-[210px] pb-24 max-[1024px]:pt-[160px] max-[560px]:pt-[130px] max-[560px]:pb-14">

        <!-- Hero -->
        <section class="container-gbe mb-16 text-center max-[560px]:mb-10">
          <h1 class="gold-text mb-4 text-[clamp(36px,5vw,56px)] font-black leading-none max-[560px]:text-[28px]">Get in Touch</h1>
          <p class="mx-auto max-w-[640px] text-[clamp(16px,1.4vw,19px)] font-normal leading-[1.7] text-gbe-muted max-[560px]:text-[15px]">
            Whether you want to nominate, apply for an award, explore a partnership, or simply learn more,
            we would love to hear from you.
          </p>
        </section>

        <!-- Reasons strip -->
        <section class="container-gbe mb-16 max-[560px]:mb-10">
          <div class="grid grid-cols-4 gap-4 max-[1024px]:grid-cols-2 max-[560px]:grid-cols-1">
            {reasons.map((reason) => (
              <div class="rounded-[12px] border border-[rgba(255,176,1,0.25)] bg-[var(--c-overlay-faint)] p-5 text-center transition-all duration-300 hover:-translate-y-1 hover:border-gbe-gold/60">
                <h3 class="gold-text mb-1.5 mt-0 text-lg font-black leading-tight">{reason.title}</h3>
                <p class="m-0 text-xs font-normal leading-[1.5] text-gbe-muted">{reason.desc}</p>
              </div>
            ))}
          </div>
        </section>

        <!-- Main grid: form + info -->
        <section class="container-gbe mb-16 max-[560px]:mb-10">
          <div class="grid grid-cols-[1.3fr_1fr] gap-8 max-[1024px]:grid-cols-1">

            <!-- Form -->
            <article class="rounded-[18px] border border-[rgba(255,176,1,0.42)] bg-[var(--c-overlay)] p-10 max-[560px]:rounded-[14px] max-[560px]:p-7">
              <h2 class="gold-text mb-6 mt-0 text-2xl font-black leading-tight max-[560px]:text-xl">Send Us a Message</h2>
              <form class="flex flex-col gap-4" action="mailto:info@gbeaward.com" method="post" enctype="text/plain">
                <div class="grid grid-cols-2 gap-4 max-[560px]:grid-cols-1">
                  <label class="flex flex-col gap-2">
                    <span class="text-sm font-bold uppercase tracking-wider text-gbe-text">Name</span>
                    <input class="rounded-lg border border-[rgba(255,176,1,0.3)] bg-gbe-bg/60 px-4 py-3 text-base text-gbe-text outline-none transition-colors focus:border-gbe-gold max-[560px]:py-2.5 max-[560px]:text-sm" type="text" name="name" placeholder="Your full name" required />
                  </label>
                  <label class="flex flex-col gap-2">
                    <span class="text-sm font-bold uppercase tracking-wider text-gbe-text">Email</span>
                    <input class="rounded-lg border border-[rgba(255,176,1,0.3)] bg-gbe-bg/60 px-4 py-3 text-base text-gbe-text outline-none transition-colors focus:border-gbe-gold max-[560px]:py-2.5 max-[560px]:text-sm" type="email" name="email" placeholder="you@example.com" required />
                  </label>
                </div>
                <div class="grid grid-cols-2 gap-4 max-[560px]:grid-cols-1">
                  <label class="flex flex-col gap-2">
                    <span class="text-sm font-bold uppercase tracking-wider text-gbe-text">Phone <span class="font-normal normal-case text-gbe-muted">(optional)</span></span>
                    <input class="rounded-lg border border-[rgba(255,176,1,0.3)] bg-gbe-bg/60 px-4 py-3 text-base text-gbe-text outline-none transition-colors focus:border-gbe-gold max-[560px]:py-2.5 max-[560px]:text-sm" type="tel" name="phone" placeholder="+44 ..." />
                  </label>
                  <label class="flex flex-col gap-2">
                    <span class="text-sm font-bold uppercase tracking-wider text-gbe-text">Organisation <span class="font-normal normal-case text-gbe-muted">(optional)</span></span>
                    <input class="rounded-lg border border-[rgba(255,176,1,0.3)] bg-gbe-bg/60 px-4 py-3 text-base text-gbe-text outline-none transition-colors focus:border-gbe-gold max-[560px]:py-2.5 max-[560px]:text-sm" type="text" name="organisation" placeholder="Company name" />
                  </label>
                </div>
                <label class="flex flex-col gap-2">
                  <span class="text-sm font-bold uppercase tracking-wider text-gbe-text">Subject</span>
                  <select class="rounded-lg border border-[rgba(255,176,1,0.3)] bg-gbe-bg/60 px-4 py-3 text-base text-gbe-text outline-none transition-colors focus:border-gbe-gold max-[560px]:py-2.5 max-[560px]:text-sm" name="subject">
                    <option>General Enquiry</option>
                    <option>Nomination / Application</option>
                    <option>Partnership Opportunity</option>
                    <option>Media / Press</option>
                  </select>
                </label>
                <label class="flex flex-col gap-2">
                  <span class="text-sm font-bold uppercase tracking-wider text-gbe-text">Message</span>
                  <textarea class="min-h-[140px] resize-y rounded-lg border border-[rgba(255,176,1,0.3)] bg-gbe-bg/60 px-4 py-3 text-base text-gbe-text outline-none transition-colors focus:border-gbe-gold max-[560px]:py-2.5 max-[560px]:text-sm" name="message" placeholder="Tell us how we can help..." rows="5" required></textarea>
                </label>
                <button class="btn-gold btn-gold-hover mt-2 w-full" type="submit">Send Message</button>
              </form>
            </article>

            <!-- Info column -->
            <div class="flex flex-col gap-6">
              <article class="overflow-hidden rounded-[18px] border border-[rgba(255,176,1,0.42)] bg-[var(--c-overlay)] max-[560px]:rounded-[14px]">
                <div class="relative h-[160px] overflow-hidden">
                  <img class="h-full w-full object-cover" src={assetPaths.redCarpet} alt="GBE Awards ceremony" width="768" height="512" loading="eager" decoding="async" />
                  <div class="absolute inset-0 bg-gradient-to-t from-[var(--c-img-gradient-bottom)] via-transparent to-transparent"></div>
                </div>
                <div class="flex flex-col gap-5 p-8 max-[560px]:p-7">
                  <h2 class="gold-text mb-0 mt-0 text-2xl font-black leading-tight max-[560px]:text-xl">Our Details</h2>
                  {contactInfo.map((item) => (
                    <div class="flex items-start gap-4">
                      <div class="grid h-10 w-10 shrink-0 place-items-center rounded-full border border-[rgba(255,176,1,0.4)] bg-gbe-bg/40">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5 text-gbe-gold" set:html={item.icon} />
                      </div>
                      <div class="pt-1">
                        <p class="m-0 mb-0.5 text-xs font-bold uppercase tracking-wider text-gbe-gold-soft">{item.label}</p>
                        {item.href ? (
                          <a class="m-0 text-[clamp(15px,1.2vw,17px)] font-medium leading-relaxed text-gbe-text transition-colors hover:text-gbe-gold" href={item.href} target={item.href.startsWith("http") ? "_blank" : undefined} rel={item.href.startsWith("http") ? "noopener noreferrer" : undefined}>{item.value}</a>
                        ) : (
                          <p class="m-0 text-[clamp(15px,1.2vw,17px)] font-medium leading-relaxed text-gbe-text">{item.value}</p>
                        )}
                      </div>
                    </div>
                  ))}
                </div>
              </article>

              <article class="rounded-[18px] border border-[rgba(255,176,1,0.42)] bg-[var(--c-overlay)] p-8 text-center max-[560px]:rounded-[14px] max-[560px]:p-7">
                <h2 class="gold-text mb-5 mt-0 text-2xl font-black leading-tight max-[560px]:text-xl">Follow Us</h2>
                <p class="mb-5 mt-0 text-sm font-normal leading-[1.6] text-gbe-muted">Stay connected for the latest updates, winner announcements, and event news.</p>
                <SocialLinks compact />
              </article>
            </div>
          </div>
        </section>

        <!-- Map-like CTA strip -->
      </main>
      <SiteFooter />
    </div>
  </body>
</html>
