---
import "../styles/global.css";
import ThemeInit from "../components/ThemeInit.astro";
import SeoHead from "../components/SeoHead.astro";
import Header from "../components/Header.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { assetPaths, categories } from "../data/home";
import { buildBreadcrumbSchema, buildPageSchema } from "../lib/seo";

const title = "About the Global Business Excellence Awards 2026";
const description =
  "About the Global Business Excellence Awards 2026, organised by London Business Consultancy in London, UK. Learn how GBE Awards recognises credible business achievement across the UK, Sri Lanka, and international markets.";

const proofPoints = [
  { value: "2026", label: "Current award year" },
  { value: "500+", label: "Nominees connected to the awards" },
  { value: "16", label: "Award categories" },
  { value: "LBC", label: "Organised by London Business Consultancy" },
];

const principles = [
  {
    title: "Credible recognition",
    text: "GBE Awards is built for organisations and individuals with real work behind their nomination. Strong applications show clear outcomes, practical achievement, and evidence that can be reviewed.",
  },
  {
    title: "Clear category fit",
    text: "Each entry is considered against the category it belongs to, so technology, media, education, finance, healthcare, hospitality, and social-impact applicants are not forced into one generic definition of success.",
  },
  {
    title: "Useful visibility",
    text: "Recognition should help people understand what a winner actually did. Public winner profiles, award records, and event communication are written to be readable, searchable, and useful after the ceremony.",
  },
];

const processSteps = [
  {
    title: "Nomination or application",
    text: "Businesses, entrepreneurs, leaders, and organisations submit their details for the most relevant GBE Awards 2026 category.",
  },
  {
    title: "Review of evidence",
    text: "The organiser reviews the entry, supporting information, public presence, and category relevance before shortlisting or publication decisions are made.",
  },
  {
    title: "Recognition and records",
    text: "Selected winners receive award recognition and a public record that connects the recipient, category, year, and award title in a clear format.",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <ThemeInit />
    <SeoHead
      title={title}
      description={description}
      path="/about"
      image={assetPaths.redCarpet}
      schema={[
        buildPageSchema({
          path: "/about",
          title,
          description,
          pageType: "AboutPage",
          image: assetPaths.redCarpet,
        }),
        buildBreadcrumbSchema([
          { name: "Home", path: "/" },
          { name: "About", path: "/about" },
        ]),
      ]}
    />
  </head>
  <body>
    <div class="min-h-screen animate-[pageFade_420ms_ease_both] bg-[var(--c-page-glow)]">
      <Header />
      <main class="bg-[radial-gradient(circle_at_50%_0%,rgba(224,176,60,0.08),transparent_420px),var(--c-bg)] pb-24 pt-[210px] max-[1024px]:pt-[160px] max-[560px]:pb-14 max-[560px]:pt-[130px]">
        <section class="container-gbe mb-14 max-w-[1120px] max-[560px]:mb-10">
          <div class="grid grid-cols-[minmax(0,1fr)_420px] items-end gap-12 max-[1024px]:grid-cols-1 max-[1024px]:gap-8">
            <div>
              <p class="mb-4 mt-0 text-xs font-black uppercase tracking-[0.22em] text-gbe-gold-soft">About GBE Awards</p>
              <h1 class="gold-text mb-6 mt-0 max-w-[900px] text-[clamp(38px,5vw,64px)] font-black leading-[0.98] max-[560px]:text-[32px]">
                Global Business Excellence Awards 2026
              </h1>
              <p class="mb-0 max-w-[760px] text-[clamp(17px,1.35vw,20px)] font-normal leading-[1.7] text-gbe-muted max-[560px]:text-[16px]">
                The Global Business Excellence Awards is a public awards platform organised by London Business Consultancy in London, UK. It recognises business leadership, enterprise, innovation, and service excellence across the UK, Sri Lanka, and international markets.
              </p>
            </div>

            <figure class="m-0 overflow-hidden rounded-[18px] border border-[rgba(255,176,1,0.32)] bg-gbe-card shadow-[var(--c-card-shadow)]">
              <img class="h-[320px] w-full object-cover max-[560px]:h-[230px]" src={assetPaths.redCarpet} alt="GBE Awards red carpet event setting" width="768" height="512" loading="eager" decoding="async" />
            </figure>
          </div>
        </section>

        <section class="container-gbe mb-14 max-w-[1120px] max-[560px]:mb-10" aria-label="GBE Awards facts">
          <div class="grid grid-cols-4 gap-4 max-[1024px]:grid-cols-2 max-[560px]:grid-cols-1">
            {proofPoints.map((item) => (
              <div class="border-y border-[rgba(255,176,1,0.28)] py-5">
                <p class="gold-text mb-1 mt-0 text-[clamp(30px,3vw,42px)] font-black leading-none">{item.value}</p>
                <p class="m-0 text-sm font-bold uppercase tracking-[0.12em] text-gbe-text">{item.label}</p>
              </div>
            ))}
          </div>
        </section>

        <section class="container-gbe mb-16 max-w-[1120px] max-[560px]:mb-12">
          <div class="grid grid-cols-[0.9fr_1.1fr] gap-12 max-[1024px]:grid-cols-1">
            <div>
              <h2 class="gold-text mb-5 mt-0 text-[clamp(28px,3vw,40px)] font-black leading-tight">What the awards are for</h2>
              <p class="mb-5 mt-0 text-[clamp(16px,1.15vw,18px)] font-normal leading-[1.75] text-gbe-muted">
                GBE Awards exists to make business recognition easier to understand. The award record should explain who was recognised, what category they were recognised in, and why that achievement matters to customers, partners, teams, and the wider market.
              </p>
              <p class="m-0 text-[clamp(16px,1.15vw,18px)] font-normal leading-[1.75] text-gbe-muted">
                The programme is intentionally broad, covering established companies, growing businesses, individual leaders, media and creative work, education, healthcare, technology, sustainability, and community impact.
              </p>
            </div>

            <div class="grid gap-4">
              {principles.map((item) => (
                <article class="rounded-[14px] border border-[rgba(255,176,1,0.26)] bg-gbe-card p-6 shadow-[var(--c-card-shadow)]">
                  <h3 class="mb-2 mt-0 text-xl font-black leading-tight text-gbe-text">{item.title}</h3>
                  <p class="m-0 text-[15px] font-normal leading-[1.7] text-gbe-muted">{item.text}</p>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section class="container-gbe mb-16 max-w-[1120px] max-[560px]:mb-12">
          <div class="grid grid-cols-2 gap-5 max-[760px]:grid-cols-1">
            <figure class="m-0 overflow-hidden rounded-[18px] border border-[rgba(255,176,1,0.28)] bg-gbe-card">
              <img class="h-[360px] w-full object-cover max-[560px]:h-[240px]" src={assetPaths.interview} alt="GBE Awards interview and media setting" width="768" height="419" loading="lazy" decoding="async" />
            </figure>
            <figure class="m-0 overflow-hidden rounded-[18px] border border-[rgba(255,176,1,0.28)] bg-gbe-card">
              <img class="h-[360px] w-full object-cover max-[560px]:h-[240px]" src={assetPaths.awardInHand} alt="GBE Awards trophy held at an awards ceremony" width="768" height="419" loading="lazy" decoding="async" />
            </figure>
          </div>
        </section>

        <section class="container-gbe mb-16 max-w-[1120px] max-[560px]:mb-12">
          <div class="grid grid-cols-[340px_minmax(0,1fr)] gap-12 max-[1024px]:grid-cols-1">
            <div>
              <p class="mb-3 mt-0 text-xs font-black uppercase tracking-[0.2em] text-gbe-gold-soft">Review path</p>
              <h2 class="gold-text mb-0 mt-0 text-[clamp(28px,3vw,40px)] font-black leading-tight">How entries move through the programme</h2>
            </div>
            <div class="grid gap-4">
              {processSteps.map((item, index) => (
                <article class="grid grid-cols-[52px_minmax(0,1fr)] gap-5 rounded-[14px] border border-[rgba(255,176,1,0.24)] bg-gbe-card p-6 shadow-[var(--c-card-shadow)] max-[560px]:grid-cols-1 max-[560px]:gap-3">
                  <div class="gold-fill grid h-12 w-12 place-items-center rounded-full text-sm font-black text-black">{String(index + 1).padStart(2, "0")}</div>
                  <div>
                    <h3 class="mb-2 mt-0 text-xl font-black leading-tight text-gbe-text">{item.title}</h3>
                    <p class="m-0 text-[15px] font-normal leading-[1.7] text-gbe-muted">{item.text}</p>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section class="container-gbe mb-16 max-w-[1120px] max-[560px]:mb-12">
          <div class="mb-8 max-w-[760px]">
            <p class="mb-3 mt-0 text-xs font-black uppercase tracking-[0.2em] text-gbe-gold-soft">Categories</p>
            <h2 class="gold-text mb-4 mt-0 text-[clamp(28px,3vw,40px)] font-black leading-tight">A practical awards framework for different sectors</h2>
            <p class="m-0 text-[clamp(16px,1.15vw,18px)] font-normal leading-[1.7] text-gbe-muted">
              The 2026 category list is designed to keep nominations specific. Entrants can choose a field that reflects how they actually create value, rather than forcing every achievement into one broad business award.
            </p>
          </div>
          <div class="grid grid-cols-4 gap-3 max-[1024px]:grid-cols-3 max-[760px]:grid-cols-2 max-[560px]:grid-cols-1">
            {categories.map((category) => (
              <div class="flex min-h-[64px] items-center gap-3 rounded-[10px] border border-[rgba(255,176,1,0.2)] bg-gbe-card px-4 py-3 shadow-[var(--c-card-shadow)]">
                <img class="h-7 w-7 shrink-0 object-contain" src={assetPaths.award} alt="" width="32" height="32" loading="lazy" decoding="async" />
                <span class="text-sm font-bold leading-tight text-gbe-text">{category}</span>
              </div>
            ))}
          </div>
        </section>

        <section class="container-gbe max-w-[1120px]">
          <div class="grid grid-cols-[minmax(0,1fr)_auto] items-center gap-8 rounded-[18px] border border-[rgba(255,176,1,0.36)] bg-[radial-gradient(circle_at_12%_20%,rgba(255,176,1,0.08),transparent_260px),var(--c-card)] p-8 shadow-[var(--c-card-shadow)] max-[760px]:grid-cols-1 max-[560px]:p-6">
            <div>
              <h2 class="gold-text mb-3 mt-0 text-[clamp(24px,2.6vw,34px)] font-black leading-tight">Apply for GBE Awards 2026</h2>
              <p class="m-0 max-w-[720px] text-[clamp(15px,1.15vw,17px)] font-normal leading-[1.7] text-gbe-muted">
                If your organisation, client, or leadership team has a clear achievement to put forward, send an enquiry and choose the most relevant award category.
              </p>
            </div>
            <a class="btn-gold btn-gold-hover" href="/contact">Contact GBE Awards</a>
          </div>
        </section>
      </main>
      <SiteFooter />
    </div>
  </body>
</html>
